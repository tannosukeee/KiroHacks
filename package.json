{
  "name": "vybe-tutor",
  "displayName": "Vybe Tutor",
  "version": "0.1.0",
  "description": "A local-first AI coding tutor that helps students understand code through contextual explanations and comprehension checks.",
  "publisher": "vybe-team",
  "main": "./dist/extension.js",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Education"
  ],
  "activationEvents": [
    "onView:vybeTutor.tutorView",
    "onCommand:vybeTutor.openTutorView",
    "onCommand:vybeTutor.explainSelection"
  ],
  "contributes": {
    "commands": [
      {
        "command": "vybeTutor.openTutorView",
        "title": "Vybe Tutor: Open Tutor View"
      },
      {
        "command": "vybeTutor.explainSelection",
        "title": "Vybe Tutor: Explain Selection"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vybeTutor",
          "title": "Vybe Tutor",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "vybeTutor": [
        {
          "type": "webview",
          "id": "vybeTutor.tutorView",
          "name": "Vybe Tutor"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p tsconfig.json",
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "build:webview": "cd webview && npx vite build",
    "watch": "tsc -watch -p tsconfig.json",
    "test": "tsc -p tsconfig.json --noEmit",
    "vscode:prepublish": "npm run build && npm run build:webview"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tannosukeee/KiroHacks.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/tannosukeee/KiroHacks/issues"
  },
  "homepage": "https://github.com/tannosukeee/KiroHacks#readme",
  "dependencies": {
    "@google/genai": "^1.51.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.118.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "esbuild": "^0.19.12",
    "postcss": "^8.4.33",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^6.0.3",
    "vite": "^5.0.12"
  }
}
